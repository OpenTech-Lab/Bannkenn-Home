# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Hub — required for scripts/push-image.sh
# Get a token at: https://hub.docker.com/settings/security (Access Tokens)
# Minimum permission needed: Read & Write
# -----------------------------------------------------------------------------
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_TOKEN=your_dockerhub_access_token
IMAGE_NAME=device-monitor
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Network — set to match your Device network interface and subnet
# Run `ip link` on the Device to find the interface name (e.g. eth0, ovs_eth0)
# Run `ip route` to find your subnet (e.g. 192.168.1.0/24)
# -----------------------------------------------------------------------------
INTERFACE=eth0
SUBNET=192.168.1.0/24
